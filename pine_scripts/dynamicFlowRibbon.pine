//@version=5
indicator("Dynamic Flow Ribbons", overlay=true)

float factor = 3.0
float dist   = ta.sma(high - low, 200)
float src    = hlc3

// Ratcheting bands (global var instead of function-local to preserve bar history)
float ub0 = ta.ema(src, 15) + factor * dist
float lb0 = ta.ema(src, 15) - factor * dist

var float upperBand = na
var float lowerBand = na

lowerBand := lb0 > nz(lowerBand[1]) or src[1] < nz(lowerBand[1]) ? lb0 : nz(lowerBand[1])
upperBand := ub0 < nz(upperBand[1]) or src[1] > nz(upperBand[1]) ? ub0 : nz(upperBand[1])

// Trend direction
var int dir = 1
if na(dist[1])
    dir := 1
else if dir == -1 and src > upperBand
    dir := 1
else if dir == 1  and src < lowerBand
    dir := -1

float midLine = math.avg(lowerBand, upperBand)

// Ribbon plots — active side fans out, inactive side hidden
plot(midLine,            "Mid",  #1add7f, linewidth=3)
plot(upperBand + dist,   "UB5",  dir == 1 ? color.new(#1add7f,  0) : na)
plot(upperBand + dist*0.5,"UB4", dir == 1 ? color.new(#1add7f, 20) : na)
plot(upperBand,          "UB3",  dir == 1 ? color.new(#1add7f, 40) : na)
plot(upperBand - dist*0.5,"UB2", dir == 1 ? color.new(#1add7f, 60) : na)
plot(upperBand - dist,   "UB1",  dir == 1 ? color.new(#1add7f, 80) : na)
plot(lowerBand + dist,   "LB5",  dir == -1 ? color.new(#e79314,  0) : na)
plot(lowerBand + dist*0.5,"LB4", dir == -1 ? color.new(#e79314, 20) : na)
plot(lowerBand,          "LB3",  dir == -1 ? color.new(#e79314, 40) : na)
plot(lowerBand - dist*0.5,"LB2", dir == -1 ? color.new(#e79314, 60) : na)
plot(lowerBand - dist,   "LB1",  dir == -1 ? color.new(#e79314, 80) : na)
